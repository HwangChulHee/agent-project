# Python
__pycache__/
*.pyc
.venv/

# ChromaDB binaries (재생성 가능)
chroma_db/chroma.sqlite3
chroma_db/*/

# JSON 결과는 보존 — chroma_db/ 전체 ignore에 negation
!chroma_db/*.json

# Backup files
*.bak
*.before_postprocess

# Editor/OS
.DS_Store
.vscode/
.idea/

# DART 원본 ZIP — 외부에서 받음
data/*.zip

# 디버그 덤프 중 큰 파생물 — 스크립트로 재생성 가능
data/debug/B_parsed/
data/debug/C_chunks/
data/debug/F_raw_xml/
